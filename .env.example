# Environment variable reference for this project.
# Copy this file to .env and fill in real values.
# Never commit .env — it is in .gitignore.

# HuggingFace cache directory (optional — defaults to ~/.cache/huggingface)
HF_HOME=

# GPU selection (optional — e.g., "0" for first GPU, "0,1" for two GPUs, "" for CPU)
CUDA_VISIBLE_DEVICES=

# Root directory for saved model checkpoints produced by the training pipeline
MODEL_OUTPUT_DIR=

# Root directory for evaluation result files produced by evaluate.py
RESULTS_DIR=
